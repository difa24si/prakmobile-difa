<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F8F9FA"
            app:title="Daftar Pertemuan"
            app:titleTextColor="#111827"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan2"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="📖\nPertemuan 2"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3908BF"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan3"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="💻\nPertemuan 3"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#4F46E5"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan4"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="🚀\nPertemuan 4"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#2563EB"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan5"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="🎯\nPertemuan 5"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#0EA5E9"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan7"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="🏆\nPertemuan 7"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#7C3AED"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan9"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="🔥\nPertemuan 9"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#9333EA"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPertemuan10"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:text="⭐\nPertemuan 10"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#A855F7"
                    app:cornerRadius="20dp"
                    app:layout_columnWeight="1"/>

            </androidx.gridlayout.widget.GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="Galeri"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>